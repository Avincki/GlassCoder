{
  // GlassCoder configuration. Everything the harness needs to talk to a model server lives
  // here: no endpoint, alias, budget or limit is hardcoded anywhere in the code (CLAUDE.md §13).
  // Override any value with an environment variable, for example GlassCoder__Agent__MaxSteps=50.
  "GlassCoder": {

    "Models": {
      "DefaultRole": "worker",
      "TelemetrySourceName": "GlassCoder.Models",
      // Attaching prompts and responses to spans is off by default (CLAUDE.md §9).
      "EnableSensitiveTelemetryData": false,

      // One entry per served role. ModelAlias is the alias the server serves - never a
      // checkpoint path; serving topology lives below the seam.
      "Roles": {
        "worker": {
          "Endpoint": "http://localhost:8001/v1",
          "ModelAlias": "worker",
          "TimeoutSeconds": 600,
          "Temperature": 0.2,
          "InputCostPerMillionTokens": 0.0,
          "OutputCostPerMillionTokens": 0.0,
          "ConstrainedDecoding": {
            "Enabled": true,
            "StrictToolSchemas": true,
            "SingleToolCallPerStep": true,
            // Set to force a tool call every step. Leave false until a terminal tool exists,
            // or the agent can never produce a final answer.
            "RequireToolCall": false,
            // Server-specific: "xgrammar", "outlines", ... Leave null for the server default.
            "GuidedDecodingBackend": null
          }
        },

        "drafter": {
          "Endpoint": "http://localhost:8002/v1",
          "ModelAlias": "drafter",
          "TimeoutSeconds": 900,
          "Temperature": 0.3,
          "ConstrainedDecoding": {
            "Enabled": true,
            "StrictToolSchemas": true
          }
        },

        "critic": {
          "Endpoint": "http://localhost:8003/v1",
          "ModelAlias": "critic",
          "TimeoutSeconds": 600,
          "Temperature": 0.0,
          "ConstrainedDecoding": {
            "Enabled": true,
            "StrictToolSchemas": true
          }
        }
      }
    },

    "Workspace": {
      // Resolved against the process working directory: run the harness from the repository
      // it should work on.
      "RepoRoot": ".",
      // Empty means "the repository root".
      "ReadablePaths": [],
      // Empty means NOTHING is writable. Opt in explicitly, for example [ "src", "tests" ].
      "WritablePaths": [],
      "FollowSymbolicLinks": false
      // DeniedGlobs defaults to .git, bin, obj, .vs and node_modules. Entries listed here are
      // added to that set rather than replacing it.
    },

    "Tools": {
      "MaxFileBytes": 524288,
      "MaxLinesPerRead": 2000,
      "MaxLineLength": 2000,
      "MaxGrepMatches": 200,
      "MaxGlobResults": 500,
      "MaxFilesSearched": 20000,
      "RegexTimeoutMilliseconds": 2000
    },

    "Agent": {
      "Role": "worker",
      "MaxSteps": 30,
      "MaxTotalTokens": 250000,
      "MaxWallClockSeconds": 900,
      "MaxCostUsd": null,
      "MaxConsecutiveInvalidToolCalls": 5
    },

    "Context": {
      // Deliberately below any served model's advertised window: effective context lags
      // advertised context, and dilution costs wall-clock on every step (CLAUDE.md §12).
      "MaxContextTokens": 48000,
      "CompactionThreshold": 0.8,
      "EnableCompaction": true,
      "KeepRecentTurns": 6,
      "MaxRootContextTokens": 6000,
      "CharactersPerToken": 4.0,
      // The lean always-loaded root. Keep this to a couple of files - everything else is
      // retrieved on demand with grep, glob and read_file.
      "RootContextFiles": []
    },

    "Verification": {
      "MaxSummarisedDiagnostics": 10,
      "IncludeWarningsInSummary": true,
      "MaxCompileFiles": 4000,
      // Compile the edit in memory before it reaches disk, and refuse it if it would break
      // something that was not already broken (CLAUDE.md §8.1).
      "VerifyEditsBeforeWrite": true,
      "RejectEditsThatBreakTheBuild": true
    },

    "VerificationLadder": {
      // Rung 3 reports and never gates, whether it runs or not.
      "RunAnalyzers": true
    },

    "Sandbox": {
      // A build is arbitrary code execution (CLAUDE.md §8.4). Docker by default, network
      // dropped except for a restore, and no silent fallback to running on the host.
      "Mode": "Docker",
      "Image": "mcr.microsoft.com/dotnet/sdk:10.0",
      "ContainerWorkspacePath": "/workspace",
      "AllowNetwork": false,
      "AllowNetworkForRestore": true,
      "AllowUnsandboxedExecution": false,
      "MemoryBytes": 4294967296,
      "CommandTimeoutSeconds": 600,
      // Read-only root filesystem, all capabilities dropped, no privilege escalation.
      "HardenContainer": true,
      "ProcessLimit": 512,
      // bash is added last and is exactly as privileged as a build (CLAUDE.md §7).
      "EnableBashTool": false
    },

    "Approval": {
      // Gate every write on a human. The desktop app can ask; the console host cannot, and
      // fails closed rather than approving silently.
      "RequireApprovalForWrites": false,
      "ApprovalTimeoutSeconds": 300
    },

    "Critique": {
      // Phase 2. Ideally a different model family from the worker, so the critic's blind spots
      // are not the worker's blind spots.
      "Enabled": false,
      "Role": "critic",
      "CriticCount": 3,
      "Gates": false
    },

    "Orchestration": {
      // Phase 5, and last on purpose: a layer over a working loop, never a substitute for one.
      "Enabled": false,
      "MaxDegreeOfParallelism": 3,
      "SubAgentMaxSteps": 12
    },

    "Provenance": {
      // Phase 6: stamp every run, and judge whether the context was newer than the code.
      "Enabled": true
    },

    "Metrics": {
      "Enabled": true,
      "Directory": "metrics",
      "FileName": "metrics.jsonl"
    },

    "Logging": {
      "Directory": "logs",
      "JsonlFileName": "glasscoder-.jsonl",
      "TextFileName": "glasscoder-.log",
      "Console": true,
      "MinimumLevel": "Information",
      "RetainedFileCountLimit": 31,
      // The redaction switch: set false to keep the step skeleton and drop all source content.
      "LogSourceContent": true,
      "MaxLoggedTextLength": 16000
    },

    "Telemetry": {
      "Enabled": true,
      "ServiceName": "GlassCoder",
      "ConsoleExporter": false,
      "OtlpEndpoint": null
    }
  }
}
