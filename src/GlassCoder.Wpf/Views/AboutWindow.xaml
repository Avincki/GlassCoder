<Window x:Class="GlassCoder.Wpf.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GlassCoder.Wpf.ViewModels"
        Title="About GlassCoder" Height="392" Width="720"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" SizeToContent="Manual" Background="White">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="248" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- The logo carries its own background - a vertical gradient - so the panel behind it is
         that same gradient, extrapolated past the image's own edges. A flat colour leaves the
         picture sitting on the panel as a visible rectangle. -->
    <Border Grid.Column="0" BorderBrush="#8D99A1" BorderThickness="0,0,1,0">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Offset="0" Color="#AFBABE" />
          <GradientStop Offset="1" Color="#97A4AC" />
        </LinearGradientBrush>
      </Border.Background>
      <Image Source="/Assets/kintsunai-logo.png" Stretch="Uniform"
             VerticalAlignment="Center" HorizontalAlignment="Center"
             RenderOptions.BitmapScalingMode="HighQuality"
             AutomationProperties.Name="Kintsunai" />
    </Border>

    <DockPanel Grid.Column="1" Margin="26,24,24,18">

      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="0,14,0,0">
        <Button Content="Settings folder" Padding="12,4" Margin="0,0,8,0" MinWidth="110"
                Command="{Binding OpenSettingsFolderCommand}"
                ToolTip="{Binding SettingsPath}" />
        <Button Content="Close" Padding="18,4" MinWidth="80" IsDefault="True" IsCancel="True" />
      </StackPanel>

      <!-- Build facts sit at the foot, above the buttons: they are what a bug report needs and
           the last thing anyone reads. -->
      <StackPanel DockPanel.Dock="Bottom">
        <Border Height="1" Background="#ECEFF1" Margin="0,0,0,10" />
        <TextBlock Text="{Binding BuildLine}" FontSize="11.5" Foreground="#78909C"
                   FontFamily="Cascadia Mono, Consolas" TextWrapping="Wrap" />
        <TextBlock Text="{Binding SettingsPath}" FontSize="11" Foreground="#90A4AE"
                   FontFamily="Cascadia Mono, Consolas" TextTrimming="CharacterEllipsis"
                   Margin="0,4,0,0" ToolTip="{Binding SettingsPath}" />
      </StackPanel>

      <StackPanel>
        <TextBlock Text="{x:Static vm:AboutViewModel.Product}" FontSize="30" FontWeight="SemiBold"
                   Foreground="#1F2933" />

        <TextBlock Text="{x:Static vm:AboutViewModel.Purpose}" FontSize="13.5" Foreground="#455A64"
                   TextWrapping="Wrap" Margin="0,8,0,0" />

        <Border Height="1" Background="#D5DDE1" Margin="0,18,0,16" />

        <TextBlock Text="{x:Static vm:AboutViewModel.Builder}" FontSize="14" FontWeight="SemiBold"
                   Foreground="#1F2933" />
        <TextBlock Text="{x:Static vm:AboutViewModel.Author}" FontSize="13" Foreground="#546E7A"
                   Margin="0,2,0,0" />
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
