<Window x:Class="GlassCoder.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GlassCoder.Wpf.ViewModels"
        xmlns:views="clr-namespace:GlassCoder.Wpf.Views"
        Title="GlassCoder" Height="760" Width="1240">

  <Window.Resources>
    <!-- Navigation is data-templated: selecting a surface swaps the view model, and WPF picks
         the view. No code-behind, no navigation service to keep in sync (CLAUDE.md §14). -->
    <DataTemplate DataType="{x:Type vm:TranscriptViewModel}">
      <views:TranscriptView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ChangesViewModel}">
      <views:ChangesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:MetricsViewModel}">
      <views:MetricsView />
    </DataTemplate>
  </Window.Resources>

  <DockPanel>
    <Border DockPanel.Dock="Top" Background="#1F2933" Padding="12,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="GlassCoder" Foreground="White" FontSize="18" FontWeight="Bold"
                   VerticalAlignment="Center" Margin="0,0,16,0" />

        <TextBox Grid.Column="1" VerticalAlignment="Center" Padding="6,4" FontSize="13"
                 Text="{Binding Goal, UpdateSourceTrigger=PropertyChanged}" />

        <Button Grid.Column="2" Content="Run" Padding="18,4" Margin="8,0,0,0"
                Command="{Binding RunCommand}" />
        <Button Grid.Column="3" Content="Cancel" Padding="14,4" Margin="8,0,0,0"
                Command="{Binding CancelCommand}" />
        <Button Grid.Column="4" Content="Settings…" Padding="14,4" Margin="16,0,0,0"
                Command="{Binding SettingsCommand}"
                ToolTip="Endpoints, API keys, budgets and guardrails - and a check that the seam works." />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="#ECEFF1" Padding="12,6">
      <TextBlock Text="{Binding Status}" Foreground="#263238" TextWrapping="Wrap" />
    </Border>

    <ListBox DockPanel.Dock="Left" Width="150" Margin="0" BorderThickness="0,0,1,0"
             ItemsSource="{Binding Surfaces}" SelectedItem="{Binding SelectedSurface}">
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding" Value="14,10" />
          <Setter Property="FontSize" Value="14" />
        </Style>
      </ListBox.ItemContainerStyle>
    </ListBox>

    <ContentControl Content="{Binding CurrentView}" />
  </DockPanel>
</Window>
